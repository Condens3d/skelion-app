# Skelion server configuration — copy to .env and fill in
NODE_ENV=production
PORT=8080
DATABASE_PATH=./data/skelion.db
DIST_PATH=../dist

# REQUIRED in production. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# First-boot admin seed (used only while the admin table is empty; remove after first start)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Set to 1 when running behind IIS/ARR, nginx, or a cloud load balancer that terminates TLS
TRUST_PROXY=1

# Skelion server configuration. Copy to server/.env and fill in.

NODE_ENV=production
PORT=8080
DIST_PATH=../dist

# PRODUCTION: PostgreSQL DSN (required; the app refuses to boot in prod without it).
#   Local docker:   postgresql://skelion_app:PASS@localhost:5432/skelion
#   Azure Database for PostgreSQL / RDS / Cloud SQL: use the provider DSN with TLS.
DATABASE_URL=

# TLS to the database. Default: TLS on, certificate verified.
#   PGSSL=disable        -> no TLS (in-cluster docker only)
#   PGSSL_NO_VERIFY=1    -> TLS on but skip cert verification (self-signed; last resort)
# PGSSL=
# PGSSL_NO_VERIFY=

# DEV ONLY: leave DATABASE_URL empty to use the local SQLite file below.
SQLITE_PATH=./data/skelion.db

# REQUIRED in production. node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
SESSION_HOURS=8

# First-boot admin seed (used only while the admin table is empty; remove after first start).
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Set to 1 behind IIS/ARR, nginx, or a cloud load balancer terminating TLS.
TRUST_PROXY=1

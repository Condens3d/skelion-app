{
  "name": "skelion-website",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npx tsc -b && npx vite build && node scripts/prerender.mjs",
    "preview": "vite preview",
    "server:dev": "npm --prefix server run dev",
    "server:start": "npm --prefix server start",
    "start": "npm run build && npm --prefix server start",
